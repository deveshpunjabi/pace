PACE_AI_PROVIDER=mock
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-1.5-flash
GOOGLE_MAPS_API_KEY=replace-with-server-or-browser-restricted-key

# Never commit .env.local. Store production values in Vercel Environment Variables.
# Set PACE_AI_PROVIDER=vertex only when GCP auth is configured in the server runtime.
