# Defaults keep PACE in safe, offline mock-AI mode (no secrets required).
PACE_AI_PROVIDER=mock

# Only used when PACE_AI_PROVIDER=vertex and server-side GCP auth is configured.
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-1.5-flash

# Never commit .env.local. Store production values in Vercel Environment Variables.
